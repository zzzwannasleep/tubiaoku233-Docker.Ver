# App
LIBRARY_TITLE=图标库
HOST=0.0.0.0
PORT=8000
FLASK_DEBUG=0

# Storage
# Local dev can use ./data
# Docker Compose will override this to /app/data
APP_DATA_DIR=./data
PUBLIC_BASE_URL=
MAX_UPLOAD_MB=20

# Security
FLASK_SECRET_KEY=
COOKIE_SECURE=0

# Admin
ADMIN_ENABLED=1
ADMIN_PASSWORD=
ADMIN_COOKIE_MAX_AGE=86400
ADMIN_PAGE_SIZE=24

# Optional background image API
RANDOM_BG_API=

# Optional default AI cutout
CLIPDROP_API_KEY=
REMOVEBG_API_KEY=

# Optional custom AI cutout
CUSTOM_AI_ENABLED=0
CUSTOM_AI_PASSWORD=
CUSTOM_AI_URL=
CUSTOM_AI_FILE_FIELD=image
CUSTOM_AI_API_KEY=
CUSTOM_AI_AUTH_HEADER=Authorization
CUSTOM_AI_AUTH_PREFIX=
